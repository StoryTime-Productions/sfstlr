{
  "name": "sfstlr",
  "version": "0.1.0",
  "description": "Slimefun raw material list and step-by-step recipe provider",
  "type": "module",
  "main": "sfstlr.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node sfstlr.js",
    "lint": "eslint src sfstlr.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
